{
  // Usa o Airbnb Style Guide como base para Node.js
  // Integra com Prettier para evitar conflitos de formatação
  "extends": ["airbnb-base", "plugin:prettier/recommended"],

  // Regras customizadas para atender às necessidades do projeto
  "rules": {
    // Permite uso de console (útil para logs e debug no backend)
    "no-console": "off",

    // Permite underscore apenas para o _id do MongoDB
    "no-underscore-dangle": ["error", { "allow": ["_id"] }],

    // Força padrão Unix (LF) para evitar problemas entre sistemas
    "linebreak-style": ["error", "unix"],

    // Ignora variável "next" não utilizada (middlewares do Express)
    "no-unused-vars": ["error", { "argsIgnorePattern": "next" }]
  },

  // Ambiente padrão do projeto
  "env": { "node": true },

  // Configurações específicas para arquivos de teste
  // Evita “vazar” globais para o restante do código
  // Padrão overrides: recomendado para não habilitar Jest no projeto todo
  "overrides": [
    {
      "files": ["**/*.test.js", "**/*jest.setup.js"],
      "env": { "jest/globals": true },
      "plugins": ["jest"],
      "extends": ["plugin:jest/recommended"]
    }
  ]
}



